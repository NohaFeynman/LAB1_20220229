<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- CABECERA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnHint"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="?" />

            <TextView
                android:id="@+id/tvDifficulty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dificultad: Fácil"
                android:textSize="18sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Puntaje: 0"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- PREGUNTA -->
        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Aquí aparecerá la pregunta"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvQuestionCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pregunta 1 de 5" />

        <TextView
            android:id="@+id/tvHintsInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pistas usadas: 0 de 3" />

        <TextView
            android:id="@+id/tvAnswerStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado: sin responder" />

        <TextView
            android:id="@+id/tvQuestionPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Puntaje en esta pregunta: 0" />

        <!-- OPCIONES -->
        <Button
            android:id="@+id/btnOption1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opción 1"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btnOption2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opción 2"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnOption3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opción 3"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnOption4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opción 4"
            android:layout_marginTop="12dp" />

        <!-- NAVEGACIÓN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPrevious"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Anterior" />

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Siguiente" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>